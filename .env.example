CODEX_AS_API_PORT=18080
CODEX_AS_API_MODEL=gpt-5.5
CODEX_AS_API_WORKERS=2
CODEX_CLI_VERSION=0.129.0

# Optional. If set, /v1 API calls must include:
# Authorization: Bearer <this value>
CODEX_AS_API_API_KEY=

# Optional. If set, webhook job callbacks include:
# Authorization: Bearer <this value>
JOB_WEBHOOK_CREDENTIAL=
JOB_WEBHOOK_TIMEOUT_SECONDS=30

# Default is the Docker named volume "codex-home".
# For a VM host path instead, set for example:
# CODEX_HOME_VOLUME=/srv/codex-as-api/codex-home
# Then run: CODEX_HOME=/srv/codex-as-api/codex-home codex login
CODEX_HOME_VOLUME=codex-home
